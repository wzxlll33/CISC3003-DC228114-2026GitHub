/.env
/.env.*
!.env.example

# Runtime data and generated local server files
/storage/*
!/storage/.gitkeep
!/storage/database/
!/storage/database/.gitkeep
!/storage/logs/
!/storage/logs/.gitkeep
!/storage/server-tui/
!/storage/server-tui/.gitkeep

# Local deployment/build staging
/_deploy_stage/

# Logs, databases, and process files
*.log
*.pid
*.sqlite
*.sqlite3
*.db

# Secrets and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Python/browser test artifacts
__pycache__/
*.pyc
/tests/screenshots/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
